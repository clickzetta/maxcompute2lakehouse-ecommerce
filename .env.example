# ClickZetta Lakehouse 连接配置 — 复制为 .env 并填写真实值
# cp .env.example .env

# 服务端点，格式：<region>-<cloud>.api.clickzetta.com
# 示例（阿里云上海）：cn-shanghai-alicloud.api.clickzetta.com
# 示例（腾讯云上海）：ap-shanghai-tencent.api.clickzetta.com
CLICKZETTA_SERVICE=cn-shanghai-alicloud.api.clickzetta.com

# 实例名（登录控制台后 URL 中的实例标识）
CLICKZETTA_INSTANCE=

# Workspace 名称
CLICKZETTA_WORKSPACE=

# 以下两项由 setup.py 自动创建，通常不需要修改
CLICKZETTA_SCHEMA=ecommerce

# VCluster 名称，可在 Studio → 计算资源 中查看
# 常见默认值：default_ap（分析型）、default_gp（通用型）
CLICKZETTA_VCLUSTER=default_ap

CLICKZETTA_USERNAME=
CLICKZETTA_PASSWORD=

# Volume 名称（setup.py 会自动创建）
CLICKZETTA_VOLUME=ecommerce_vol

# cz-cli profile 名称（与 setup.py 使用同一上下文）
CZ_PROFILE=ecommerce_dev
